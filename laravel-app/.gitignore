# =============================================================================
# Laravel — AI Health Intelligence
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
/vendor/
/node_modules/
/auth.json

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit .env — it contains DB passwords, API keys, app secrets
.env
.env.*
!.env.example

# ── Application Key & Storage Keys ───────────────────────────────────────────
/storage/*.key

# ── Uploaded Patient Documents (runtime data) ─────────────────────────────────
# These are user-uploaded medical files — private, never go to version control
/storage/app/documents/
/storage/app/private/
/storage/app/public/

# ── Laravel Generated / Cache ─────────────────────────────────────────────────
/bootstrap/cache/*.php
/public/storage
/public/hot
/public/build
/storage/pail

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
/storage/logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.phpunit.result.cache
/.phpunit.cache
/coverage/
.phpunit.coverage

# ── Database ──────────────────────────────────────────────────────────────────
/database/database.sqlite
/database/database.sqlite-shm
/database/database.sqlite-wal

# ── Build / Compiled Assets ───────────────────────────────────────────────────
/public/mix-manifest.json
npm-debug.log
npm-debug.log.*
yarn-error.log

# ── OS Generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE & Editors ─────────────────────────────────────────────────────────────
/.idea/
/.fleet/
/.nova/
/.vscode/
/.zed/
.phpactor.json
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.settings/
*.iml

# ── Laravel Sail / Homestead ──────────────────────────────────────────────────
Homestead.json
Homestead.yaml
docker-compose.override.yml

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php
